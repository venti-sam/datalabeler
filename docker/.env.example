# Machine-local settings for docker compose. Copy to `.env` (gitignored) and fill
# in; compose reads `.env` automatically because it sits next to the compose file,
# so `./join.sh sam3` and hand-run `docker compose -f docker/docker-compose.yml
# run ...` both pick it up. `docker/_env.sh` (run by build.sh/start.sh) creates it
# and keeps DL_UID/DL_GID current without touching anything else here.
#
# Real secrets live in `.env`, never in this file and never in the compose file.

# Container user, so pipeline output in work/ stays deletable without sudo.
# Managed by _env.sh; you should not need to set these by hand.
DL_UID=1000
DL_GID=1000

# Gated facebook/sam3 weights for Stage 2. Request access at
# https://huggingface.co/facebook/sam3, then create a token at
# https://huggingface.co/settings/tokens. Without it `autolabel` cannot download
# the checkpoint on first run (once cached in docker/checkpoints it is only
# needed again for a new model version).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: read bags from outside the repo, so you can label other datasets
# without copying them into data/bags. Absolute path, or relative to docker/.
# Unset = the repo's own data/bags.
#DL_BAGS_DIR=/home/you/somewhere/bags

# Optional: Stage 3 CVAT credentials, if you use the automated round-trip.
# `docker/cvat.sh superuser` will create this exact login on the CVAT server;
# `cvat-push`/`cvat-pull` then authenticate with it.
#CVAT_USER=admin
#CVAT_PASSWORD=

# Optional: where `docker/cvat.sh` checks out the CVAT server repo. Default is a
# sibling `cvat/` next to this repo. Pin a release with CVAT_REF (default: the
# latest tag). CVAT's own images are large (several GB on first `up`).
#CVAT_DIR=/path/to/cvat
#CVAT_REF=v2.70.0
